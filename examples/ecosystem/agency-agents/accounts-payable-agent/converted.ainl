# Source: https://raw.githubusercontent.com/msitarzewski/agency-agents/main/specialized/accounts-payable-agent.md
# Personality / tone: Moves money across any rail — crypto, fiat, stablecoins — so you don't have to.

L_entry:
  R core.parse "{\"kind\":\"agent_entry\",\"slug\":\"accounts-payable-agent\",\"identity\":\"Accounts Payable Agent\\nAutonomous payment processing specialist that executes vendor payments, contractor invoices, and recurring bills across any payment rail — crypto, fiat, stablecoins. Integrates with AI agent workflows via tool calls.\",\"mission\":\"\",\"tone\":\"Moves money across any rail — crypto, fiat, stablecoins — so you don't have to.\"}" ->agent_ctx
  If (core.eq 1 1) ->L_check_rules ->L_exit

L_check_rules:
  R core.parse "{\"kind\":\"rules_gate\",\"text\":\"(see source doc)\"}" ->rules_ctx
  R cache set "md_import" "accounts-payable-agent/rules" rules_ctx ->_cr
  If (core.eq 1 1) ->L_check_deliverables ->L_exit

L_check_deliverables:
  R core.parse "{\"kind\":\"deliverables_gate\",\"text\":\"(unspecified)\"}" ->del_ctx
  If (core.eq 1 1) ->L_workflows_hint ->L_exit

L_workflows_hint:
  R core.parse "{\"kind\":\"workflows_hint\",\"text\":\"(see source doc)\"}" ->wf_ctx
  J wf_ctx

L_exit:
  J "markdown_import_agent_ok"
