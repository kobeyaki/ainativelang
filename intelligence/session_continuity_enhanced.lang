# Session Continuity (Enhanced Intelligence)
# ============================================
# Monitors session-scoped memory keys, checks bootstrap context freshness,
# and ensures continuity data is available for new sessions.
# Runs every 30 minutes. Pure compute — no LLM calls.
S core cron "*/30 * * * *"

# ── Entry: timestamp and check for bootstrap context ──
L0:
  R core now ->ts
  R core iso ->isoTs
  # Check if bootstrap context exists and is fresh
  R cache get "workflow" "context_injection_last" ->lastInjection
  X hasInjection (ne lastInjection null)
  If hasInjection ->L1 ->L2

# ── Check freshness of last injection ──
L1:
  X age (sub ts lastInjection)
  # Stale if older than 1 hour (3600s)
  X isStale (gt age 3600)
  If isStale ->L3 ->L4

# ── No injection exists — flag it ──
L2:
  X status "no_bootstrap"
  X msg (core.concat "Session continuity — no bootstrap context found at " isoTs)
  R queue Put "notify" msg ->_
  R cache set "monitor_heartbeat" "session_continuity_intel" ts ->_
  J status

# ── Stale injection — trigger refresh ──
L3:
  X ageMin (core.idiv age 60)
  X ageStr (core.stringify ageMin)
  X status "stale"
  X msg (core.concat "Session continuity — bootstrap context is " ageStr "min old, needs refresh")
  R queue Put "notify" msg ->_
  R cache set "monitor_heartbeat" "session_continuity_intel" ts ->_
  J status

# ── Fresh injection — check stats ──
L4:
  R cache get "workflow" "context_injection_lines" ->lineCount
  R cache get "workflow" "context_injection_tokens" ->tokenCount
  X hasLines (ne lineCount null)
  If hasLines ->L5 ->L6

# ── Report with stats ──
L5:
  X lineStr (core.stringify lineCount)
  X tokStr (core.stringify tokenCount)
  X msg (core.concat "Session continuity OK — " lineStr " lines, " tokStr " tokens injected at " isoTs)
  R queue Put "notify" msg ->_
  R cache set "monitor_heartbeat" "session_continuity_intel" ts ->_
  R cache set "session" "continuity_last_ok" ts ->_
  X rec_id (core.concat "continuity-" isoTs)
  X rec_payload {"status":"ok","line_count":lineCount,"token_count":tokenCount,"ts":ts}
  X rec_meta {"source":"intelligence.session_continuity_enhanced","confidence":1.0,"tags":["intelligence","continuity","session"],"valid_at":isoTs}
  R memory put "workflow" "workflow.session_continuity" rec_id rec_payload 604800 rec_meta ->_
  J lineCount

# ── Report without stats ──
L6:
  X msg (core.concat "Session continuity OK — bootstrap context fresh at " isoTs)
  R queue Put "notify" msg ->_
  R cache set "monitor_heartbeat" "session_continuity_intel" ts ->_
  R cache set "session" "continuity_last_ok" ts ->_
  J 0
