# Memory Consolidation v2 — Terse Format
# Runs daily at 03:30. Scans recent memory/*.md files, extracts high-signal
# lines, converts to terse bullet format (D:/P:/T:/L:/S:), appends to MEMORY.md.
# Pure compute — no LLM calls. Keyword-based extraction only.
# Uses X dst push dst item (not Append — Append is not lowered to IR).
S core cron "30 3 * * *"

L0:
  R core iso ->iso
  X today_str (core.substr iso 0 10)

  # List memory directory
  R fs list "memory" ->files
  X total (core.len files)
  Set zero 0
  X noFiles (core.eq total zero)
  If noFiles ->L_done_empty ->L_select_recent

L_select_recent:
  # Take last 10 files (most recent days)
  Set maxFiles 10
  X startIdx (core.sub total maxFiles)
  Set zero1 0
  X startSafe (core.max startIdx zero1)
  Set recentFiles []
  Set ri startSafe
  J L_collect_recent

L_collect_recent:
  X rcDone (core.gte ri total)
  If rcDone ->L_read_memory ->L_add_recent

L_add_recent:
  X fname get files ri
  X isMd (core.contains fname ".md")
  If isMd ->L_append_recent ->L_skip_recent

L_append_recent:
  X recentFiles push recentFiles fname
  J L_skip_recent

L_skip_recent:
  Set one1 1
  X ri (core.add ri one1)
  J L_collect_recent

L_read_memory:
  # Read existing MEMORY.md to avoid duplicating
  R fs read "MEMORY.md" ->existingMem
  X existingLower (core.lower existingMem)

  X recentCount (core.len recentFiles)
  Set zero2 0
  X noRecent (core.eq recentCount zero2)
  If noRecent ->L_done_empty ->L_process_init

L_process_init:
  Set newItems []
  Set pi 0
  J L_process_file

L_process_file:
  X pfDone (core.gte pi recentCount)
  If pfDone ->L_check_results ->L_read_one

L_read_one:
  X pfile get recentFiles pi
  X ppath (core.concat "memory/" pfile)
  R fs read ppath ->fcontent
  X flines (core.split fcontent "\n")
  X fcount (core.len flines)
  Set li 0
  J L_scan_lines

L_scan_lines:
  X slDone (core.gte li fcount)
  If slDone ->L_next_file ->L_eval_line

L_eval_line:
  X rawLine get flines li
  X trimLine (core.trim rawLine)
  X lineLen (core.len trimLine)

  # Skip empty/short lines
  Set minChars 20
  X tooShort (core.lt lineLen minChars)
  If tooShort ->L_next_line ->L_keyword_check

L_keyword_check:
  X lower (core.lower trimLine)

  # Check for high-signal keywords
  X kDecision (core.contains lower "decision")
  X kPreference (core.contains lower "preference")
  X kTodo (core.contains lower "todo")
  X kImportant (core.contains lower "important")
  X kLesson (core.contains lower "lesson")
  X kSetting (core.contains lower "setting")
  X kRequires (core.contains lower "requires")
  X kConfig (core.contains lower "config")
  X kFixed (core.contains lower "fixed")
  X kChanged (core.contains lower "changed")
  X kCreated (core.contains lower "created")
  X kEnabled (core.contains lower "enabled")
  X kDisabled (core.contains lower "disabled")

  # Check if line already has terse prefix
  X hasD (core.contains trimLine "D: ")
  X hasP (core.contains trimLine "P: ")
  X hasT (core.contains trimLine "T: ")
  X hasL (core.contains trimLine "L: ")
  X hasS (core.contains trimLine "S: ")

  # Combine: terse prefix OR (keyword AND long enough)
  X isTerse (core.or hasD (core.or hasP (core.or hasT (core.or hasL hasS))))
  X hasKeyword (core.or kDecision (core.or kPreference (core.or kTodo (core.or kImportant (core.or kLesson (core.or kSetting (core.or kRequires (core.or kConfig (core.or kFixed (core.or kChanged (core.or kCreated (core.or kEnabled kDisabled))))))))))))
  Set minLong 60
  X isLong (core.gt lineLen minLong)
  X keywordAndLong (core.and hasKeyword isLong)
  X keep (core.or isTerse keywordAndLong)
  If keep ->L_dedup_check ->L_next_line

L_dedup_check:
  # Skip if this line (lowercased) already exists in MEMORY.md
  X alreadyExists (core.contains existingLower lower)
  If alreadyExists ->L_next_line ->L_classify_and_add

L_classify_and_add:
  # If already terse-prefixed, add as-is
  If isTerse ->L_add_as_is ->L_auto_prefix

L_auto_prefix:
  # Classify by keyword priority using nested ite (if-then-else)
  # D: decision/fixed/changed, T: todo/requires, L: lesson/important, S: setting/config/enabled/disabled/created, P: default
  X isDecisionType (core.or kDecision (core.or kFixed kChanged))
  X isTodoType (core.or kTodo kRequires)
  X isLessonType (core.or kLesson kImportant)
  X isSettingType (core.or kSetting (core.or kConfig (core.or kEnabled (core.or kDisabled kCreated))))

  # Compute prefix using ite chain
  X prefix (ite isDecisionType "D: " (ite isTodoType "T: " (ite isLessonType "L: " (ite isSettingType "S: " "P: "))))

  # Truncate line to 120 chars max for terseness
  Set maxTrunc 120
  X needsTrunc (core.gt lineLen maxTrunc)
  If needsTrunc ->L_trunc_line ->L_add_prefixed

L_trunc_line:
  X trimLine (core.substr trimLine 0 maxTrunc)
  J L_add_prefixed

L_add_prefixed:
  X terseLine (core.concat prefix trimLine)
  X newItems push newItems terseLine
  J L_next_line

L_add_as_is:
  X newItems push newItems trimLine
  J L_next_line

L_next_line:
  Set one2 1
  X li (core.add li one2)
  J L_scan_lines

L_next_file:
  Set one3 1
  X pi (core.add pi one3)
  J L_process_file

L_check_results:
  X itemCount (core.len newItems)
  Set zero3 0
  X noNew (core.eq itemCount zero3)
  If noNew ->L_done_none ->L_write

L_write:
  # Build section and append to MEMORY.md
  X sectionHeader (core.concat "\n\n## Consolidated — " today_str "\n")
  X itemText (core.join "\n" newItems)
  X section (core.concat sectionHeader itemText "\n")
  X finalMem (core.concat existingMem section)
  R fs write "MEMORY.md" finalMem ->_

  # Notify
  X msg (core.concat "Consolidation: " (core.stringify itemCount) " terse items from " (core.stringify recentCount) " files")
  R queue Put "notify" {"module":"memory_consolidation","status":"ok","message":msg} ->_
  J msg

L_done_empty:
  R core concat "No memory files to consolidate" ->msg
  J msg

L_done_none:
  R core concat "No new items found" ->msg
  J msg
