// Prisma schema generated from D (Data) ops

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Position {
  id  Int
  symbol  String
  volume  Float
  price  Float
  sl  Float
  tp  Float
}

model Signal {
  id    Int     @id @default(autoincrement())
  symbol  String
  dir  String
  strength  Float
}

