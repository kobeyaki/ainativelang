{
  "schema_version": "1.0",
  "support_levels": {
    "canonical": "Recommended public path for docs, onboarding, training, and future convergence work.",
    "compatible": "Supported for continuity and migration, but not the preferred path for new examples or canonical training.",
    "deprecated": "Accepted temporarily through compatibility policy, but on a retirement path with warnings and migration guidance."
  },
  "syntax": {
    "service_header": {
      "form": "S <name> <mode> [path]",
      "level": "canonical"
    },
    "endpoint_binding": {
      "form": "E <path> <method> ->L<label> [->return_var]",
      "level": "canonical"
    },
    "label_block": {
      "form": "L<label>:",
      "level": "canonical"
    },
    "adapter_call_dotted": {
      "form": "R <adapter>.<VERB> <target> [args...] ->out",
      "level": "canonical"
    },
    "adapter_call_split_tokens": {
      "form": "R <adapter> <verb> ...",
      "level": "compatible"
    },
    "strict_quoted_literals": {
      "form": "Quote string literals in read positions under strict mode",
      "level": "canonical"
    },
    "inline_multi_step_label_line": {
      "form": "L1: Set flag true If flag ->L2 ->L3",
      "level": "compatible"
    }
  },
  "ops": {
    "S": "canonical",
    "D": "canonical",
    "E": "canonical",
    "L": "canonical",
    "R": "canonical",
    "J": "canonical",
    "If": "canonical",
    "Err": "canonical",
    "Retry": "canonical",
    "Call": "canonical",
    "Set": "canonical",
    "Cr": "canonical",
    "Sc": "canonical",
    "Filt": "compatible",
    "Sort": "compatible",
    "X": "compatible",
    "Loop": "compatible",
    "While": "compatible",
    "CacheGet": "compatible",
    "CacheSet": "compatible",
    "QueuePut": "compatible",
    "Tx": "compatible",
    "Enf": "compatible"
  },
